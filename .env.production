# ==========================================
# F1 TERMINAL - PRODUCTION ENVIRONMENT VARIABLES
# ==========================================

# [BACKEND API GATEWAY]
# The domain of your backend API services (e.g., https://f1-api.shuoguo.org/api/v1)
NEXT_PUBLIC_API_URL=https://f1-api.yourdomain.com/api/v1

# [FRONTEND DOMAIN (CORS SECURITY)]
# The domain of your frontend (e.g., https://f1.shuoguo.org)
# Used by the backend to securely map CORS Allowed Origins.
FRONTEND_URL=https://f1.yourdomain.com

# [BACKEND SECRETS (Optional)]
# Add DeepSeek or OpenAI keys here if environment overrides are required
# DEEPSEEK_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxx"
