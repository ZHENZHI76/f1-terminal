# ==========================================
# F1 TERMINAL - PRODUCTION ENVIRONMENT VARIABLES
# ==========================================

# [FRONTEND ROUTING - BUILD TIME]
# This URL is baked into the Next.js JavaScript bundle during `docker-compose build`.
# It MUST point to your reverse-proxied Backend API Gateway's public domain.
# DO NOT use localhost or raw IP addresses in production.
NEXT_PUBLIC_API_URL=https://f1-api.shuoguo.org

# [BACKEND CORS - RUNTIME]
# Comma-separated list of allowed origins for the backend CORS middleware.
# Must include the frontend's public domain.
CORS_ORIGINS=https://f1.shuoguo.org

# [BACKEND SECRETS]
# DeepSeek-Reasoner API Key (Required for INSIGHT command)
# Get your key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
