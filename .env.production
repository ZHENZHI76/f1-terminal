# ==========================================
# F1 TERMINAL - PRODUCTION ENVIRONMENT VARIABLES
# ==========================================

# [FRONTEND ROUTING — BUILD TIME]
# CRITICAL: This value is baked into the Next.js JS bundle at build time.
# It MUST point to the reverse-proxied Backend API Gateway (via HTTPS).
# After changing this value, you MUST rebuild the frontend image!
NEXT_PUBLIC_API_URL=https://f1-api.shuoguo.org

# [BACKEND CORS — RUNTIME]
# Comma-separated list of allowed frontend origins.
# Must match the exact protocol + domain the user accesses in the browser.
CORS_ORIGINS=https://f1.shuoguo.org

# [BACKEND SECRETS (Optional)]
# DEEPSEEK_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxx"
