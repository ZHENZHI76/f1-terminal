# ==========================================
# F1 TERMINAL - ENVIRONMENT TEMPLATE
# ==========================================
# Copy this file to .env.production and fill in your real values:
#   cp .env.example .env.production
#
# NEVER commit .env.production to Git!

# [FRONTEND — BUILD TIME]
# Your backend API domain (reverse-proxied via 1Panel/Nginx)
NEXT_PUBLIC_API_URL=https://api.f1.yourdomain.com

# [BACKEND — RUNTIME]
# Comma-separated CORS whitelist (must match user-facing frontend domain)
CORS_ORIGINS=https://f1.yourdomain.com

# [SECRETS (Optional)]
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
